# CPE 短信转发配置模板
# 复制此文件为 .env 并填入实际配置

# 路由器配置
CPE_HOST=http://192.168.1.1
CPE_USERNAME=admin
CPE_PASSWORD=your-password

# 检查间隔（秒）
CHECK_INTERVAL=3.0

# 被登出后等待时间（秒）
WAIT_AFTER_LOGOUT=600.0

# ============ 通知器配置（按需启用）============

# 飞书 Webhook 机器人（推荐）
# 获取方式：飞书群 -> 群设置 -> 群机器人 -> 添加机器人 -> 自定义机器人
# FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/xxx

# Bark 推送（iOS）
# BARK_KEY=your-bark-key
# BARK_SERVER=https://api.day.app

# 飞书应用机器人（备选）
# FEISHU_APP_ID=cli_xxx
# FEISHU_APP_SECRET=xxx
# FEISHU_RECEIVE_ID=ou_xxx

# 自定义 Webhook
# WEBHOOK_URL=https://your-server.com/webhook
